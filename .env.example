# ---------------------------------------------------------------------------
# ArcLibrary — environment configuration (sample)
# Copy to `.env.local` (dev) or set in your hosting provider's dashboard.
# ---------------------------------------------------------------------------

# Required to enable the AI assistant. Without this the panel mounts but
# shows a "not configured" notice.
OPENAI_API_KEY=

# OpenAI-compatible endpoint. Works with OpenAI, Azure, vLLM, Ollama,
# DeepSeek, Qwen, OpenRouter, Together, Groq, ... anything that speaks
# /v1/chat/completions with tool-calling support.
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name. Pick something with tool-calling support.
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Rate limiting (in-memory token bucket on /api/chat)
# ---------------------------------------------------------------------------

# Burst capacity (requests). Default 20.
ARC_AI_RATE_CAPACITY=20

# Refill window in ms. Default 60000 (1 minute).
ARC_AI_RATE_WINDOW_MS=60000

# ---------------------------------------------------------------------------
# Origin allow-list for /api/chat. Comma-separated hostnames or full URLs.
# The request's own Host is always allowed; this only matters when you
# expose the API under multiple hostnames (e.g. apex + www) or via a CDN
# that rewrites Origin.
# ---------------------------------------------------------------------------
ARC_AI_ALLOWED_ORIGINS=

# Set to 1 to allow requests with NO Origin/Referer header in production
# (e.g. server-to-server scripts). NOT recommended for public deploys.
ARC_AI_ALLOW_NO_ORIGIN=0

# ---------------------------------------------------------------------------
# SEO
# ---------------------------------------------------------------------------

# REQUIRED for production. The fully qualified site URL is used as the
# base for canonical links, Open Graph URLs, sitemap entries, and OG
# image references. Without it, those will point at a placeholder host.
NEXT_PUBLIC_SITE_URL=https://wiki.example.com

# Optional. Used for Twitter Card site/creator tags. Include the leading "@".
NEXT_PUBLIC_TWITTER_HANDLE=

# ---------------------------------------------------------------------------
# Analytics (Rybbit)
# ---------------------------------------------------------------------------
#
# Both vars are intentionally OPT-IN. If you fork this repo or clone it for
# your own deployment, leave them blank — that way you won't accidentally
# pipe traffic into someone else's analytics account just by deploying.
# Set them ONLY in the canonical deployment's environment (e.g. the Vercel
# project dashboard), never commit them to the repo.
#
# Get a site ID from your Rybbit dashboard. The script URL defaults to
# https://app.rybbit.io/api/script.js — override only if you self-host
# Rybbit on a custom domain.

NEXT_PUBLIC_RYBBIT_SITE_ID=
NEXT_PUBLIC_RYBBIT_SCRIPT_URL=
